<% layout("layouts/boilerplate") %>

<div class="space-y-6">
    
    <!-- Header with Actions -->
    <div class="flex flex-wrap justify-between items-center gap-4">
        <div>
            <h2 class="text-2xl font-bold text-gray-800 dark:text-white">Diploma Applications</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Manage and track all diploma program enrollments</p>
        </div>
        <div class="flex gap-3">
            <a href="/admin/diploma/export?status=<%= currentStatus %>" class="px-4 py-2 bg-green-600 text-white rounded-lg text-sm hover:bg-green-700 transition">
                <i class="fas fa-download mr-2"></i> Export CSV
            </a>
        </div>
    </div>
    
    <!-- Filters -->
    <div class="bg-white dark:bg-gray-800 rounded-xl p-4 shadow-sm">
        <form method="GET" class="flex flex-wrap gap-4 items-end">
            <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Status Filter</label>
                <select name="status" class="px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg text-sm dark:bg-gray-700">
                    <option value="all" <%= currentStatus === 'all' ? 'selected' : '' %>>All Status</option>
                    <option value="pending" <%= currentStatus === 'pending' ? 'selected' : '' %>>Pending</option>
                    <option value="contacted" <%= currentStatus === 'contacted' ? 'selected' : '' %>>Contacted</option>
                    <option value="enrolled" <%= currentStatus === 'enrolled' ? 'selected' : '' %>>Enrolled</option>
                    <option value="rejected" <%= currentStatus === 'rejected' ? 'selected' : '' %>>Rejected</option>
                </select>
            </div>
            <div class="flex-1 min-w-[200px]">
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Search</label>
                <input type="text" name="search" value="<%= searchQuery %>" placeholder="Name, Email or Phone..." class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg text-sm dark:bg-gray-700">
            </div>
            <div>
                <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm hover:bg-blue-700 transition">
                    <i class="fas fa-search mr-2"></i> Filter
                </button>
                <% if (searchQuery || currentStatus !== 'all') { %>
                    <a href="/admin/diploma" class="px-4 py-2 bg-gray-500 text-white rounded-lg text-sm hover:bg-gray-600 transition ml-2">
                        <i class="fas fa-times mr-2"></i> Clear
                    </a>
                <% } %>
            </div>
        </form>
    </div>
    
    <!-- Applications Table -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50 dark:bg-gray-700">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300">Name</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300">Email</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300">Phone</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300">City</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300">Mode</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300">Batch</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300">Date</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 dark:text-gray-300">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                    <% if (applications && applications.length > 0) { %>
                        <% applications.forEach(app => { %>
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                                <td class="px-6 py-3 text-sm font-medium text-gray-900 dark:text-white"><%= app.fullName %></td>
                                <td class="px-6 py-3 text-sm text-gray-600 dark:text-gray-400"><%= app.email %></td>
                                <td class="px-6 py-3 text-sm text-gray-600 dark:text-gray-400"><%= app.phone %></td>
                                <td class="px-6 py-3 text-sm text-gray-600 dark:text-gray-400"><%= app.city %></td>
                                <td class="px-6 py-3 text-sm capitalize text-gray-600 dark:text-gray-400"><%= app.preferredMode %></td>
                                <td class="px-6 py-3 text-sm capitalize text-gray-600 dark:text-gray-400"><%= app.preferredBatch %></td>
                                <td class="px-6 py-3">
                                    <span class="px-2 py-1 text-xs rounded-full status-<%= app.status %>">
                                        <%= app.status.charAt(0).toUpperCase() + app.status.slice(1) %>
                                    </span>
                                </td>
                                <td class="px-6 py-3 text-sm text-gray-600 dark:text-gray-400"><%= new Date(app.createdAt).toLocaleDateString() %></td>
                                <td class="px-6 py-3">
                                    <a href="/admin/diploma/<%= app._id %>" class="text-blue-600 hover:text-blue-800">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="9" class="px-6 py-8 text-center text-gray-500">No applications found</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700 flex justify-between items-center">
                <div class="text-sm text-gray-500">Showing <%= (currentPageNum - 1) * 20 + 1 %> to <%= Math.min(currentPageNum * 20, total) %> of <%= total %> entries</div>
                <div class="flex gap-2">
                    <% if (currentPageNum > 1) { %>
                        <a href="?page=<%= currentPageNum - 1 %><%= currentStatus !== 'all' ? '&status=' + currentStatus : '' %><%= searchQuery ? '&search=' + searchQuery : '' %>" class="px-3 py-1 border border-gray-300 rounded text-sm hover:bg-gray-50">Previous</a>
                    <% } %>
                    <% if (currentPageNum < totalPages) { %>
                        <a href="?page=<%= currentPageNum + 1 %><%= currentStatus !== 'all' ? '&status=' + currentStatus : '' %><%= searchQuery ? '&search=' + searchQuery : '' %>" class="px-3 py-1 border border-gray-300 rounded text-sm hover:bg-gray-50">Next</a>
                    <% } %>
                </div>
            </div>
        <% } %>
    </div>
</div>

<style>
.status-pending { background: #fef3c7; color: #92400e; }
.status-contacted { background: #dbeafe; color: #1e40af; }
.status-enrolled { background: #d1fae5; color: #065f46; }
.status-rejected { background: #fee2e2; color: #991b1b; }
.dark .status-pending { background: #78350f; color: #fde68a; }
.dark .status-contacted { background: #1e3a8a; color: #93c5fd; }
.dark .status-enrolled { background: #064e3b; color: #6ee7b7; }
.dark .status-rejected { background: #7f1d1d; color: #fca5a5; }
</style>