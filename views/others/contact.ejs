<% layout("/layouts/boilerplate") -%>

<!-- Hero Section -->
<section class="relative bg-gradient-to-r from-blue-900 to-cyan-800 text-white py-20 overflow-hidden">
    
    
<div class="absolute inset-0 opacity-40 pointer-events-none">
    <canvas id="particleCanvas" class="block w-full h-full"></canvas>
</div>

    <div class="relative max-w-7xl mx-auto px-4 py-20 md:py-28 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Contact Us</h1>
        <p class="text-lg text-gray-200 max-w-2xl mx-auto">
            Get in touch with our team. We're here to help you with your cybersecurity journey.
        </p>
    </div>
</section>

<!-- Contact Section -->
<section class="py-16 bg-white dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-3 gap-8">
            
            <!-- Contact Information Cards -->
            <div class="lg:col-span-1 space-y-6">
                <!-- <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-6 shadow-lg">
                    <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mb-4">
                        <i class="fas fa-map-marker-alt text-blue-600 text-xl"></i>
                    </div>
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Visit Us</h3>
                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                        123 Cybersecurity Avenue<br>
                        Silicon Valley, CA 94025<br>
                        United States
                    </p>
                </div> -->
                
                <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-6 shadow-lg">
                    <div class="w-10 h-10 bg-cyan-100 dark:bg-cyan-900/30 rounded-lg flex items-center justify-center mb-4">
                        <i class="fas fa-envelope text-cyan-600 text-lg"></i>
                    </div>
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Email Us</h3>
                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                        <a href="mailto:info@secureaegix.com" class="hover:text-blue-600 transition-colors">info@secureaegix.com</a><br>
                        
                    </p>
                </div>
                
                <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-6 shadow-lg">
                    <div class="w-10 h-10 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mb-4">
                        <i class="fas fa-phone text-purple-600 text-lg"></i>
                    </div>
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Call Us</h3>
                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                        <a href="tel:+1234567890" class="hover:text-blue-600 transition-colors">+1 (234) 567-8900</a><br>
                        <span class="text-xs">Mon-Fri, 9AM - 6PM PST</span>
                    </p>
                </div>
                
                <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-6 shadow-lg">
                    <div class="w-10 h-10 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mb-4">
                        <i class="fas fa-clock text-green-600 text-lg"></i>
                    </div>
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Support Hours</h3>
                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                        24/7 Emergency Support<br>
                        Email response within 24 hours
                    </p>
                </div>
            </div>
            
            <!-- Contact Form -->
            <div class="lg:col-span-2">
                <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-8 shadow-lg">
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Send us a Message</h2>
                    <p class="text-gray-600 dark:text-gray-400 mb-6">Fill out the form below and we'll get back to you as soon as possible.</p>
                    
                    <form action="/contact" method="POST" class="space-y-5">
                        <div class="grid md:grid-cols-2 gap-5">
                            <div>
                                <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                    Full Name <span class="text-red-500">*</span>
                                </label>
                                <input type="text" id="name" name="name" required
                                       class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700 dark:text-white transition-colors"
                                       placeholder="John Doe">
                            </div>
                            
                            <div>
                                <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                    Email Address <span class="text-red-500">*</span>
                                </label>
                                <input type="email" id="email" name="email" required
                                       class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700 dark:text-white transition-colors"
                                       placeholder="john@example.com">
                            </div>
                        </div>
                        
                        <div class="grid md:grid-cols-2 gap-5">
                            <div>
                                <label for="phone" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                    Phone Number
                                </label>
                                <input type="tel" id="phone" name="phone"
                                       class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700 dark:text-white transition-colors"
                                       placeholder="+1 (234) 567-8900">
                            </div>
                            
                            <div>
                                <label for="subject" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                    Subject <span class="text-red-500">*</span>
                                </label>
                                <select id="subject" name="subject" required
                                        class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700 dark:text-white transition-colors">
                                    <option value="">Select a subject</option>
                                    <option value="General Inquiry">General Inquiry</option>
                                    <option value="Course Information">Course Information</option>
                                    <option value="Certification Support">Certification Support</option>
                                    <option value="Security Services">Security Services</option>
                                    <option value="Corporate Training">Corporate Training</option>
                                    <option value="Technical Support">Technical Support</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                        </div>
                        
                        <div>
                            <label for="message" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                Message <span class="text-red-500">*</span>
                            </label>
                            <textarea id="message" name="message" rows="5" required
                                      class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700 dark:text-white transition-colors resize-none"
                                      placeholder="Tell us how we can help you..."></textarea>
                        </div>
                        
                        <div>
                            <button type="submit" 
                                    class="w-full md:w-auto px-8 py-3 bg-gradient-to-r from-blue-600 to-cyan-600 text-white font-semibold rounded-lg hover:shadow-lg transition-all">
                                Send Message
                                <i class="fas fa-paper-plane ml-2"></i>
                            </button>
                        </div>
                        
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-4">
                            <i class="fas fa-lock mr-1"></i> Your information is secure and will not be shared with third parties.
                        </p>
                    </form>
                </div>
            </div>
            
        </div>
    </div>
</section>


<!-- FAQ Section -->
<section class="py-16 bg-white dark:bg-gray-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-2">Frequently Asked Questions</h2>
            <p class="text-gray-600 dark:text-gray-400">Quick answers to common questions</p>
        </div>
        
        <div class="space-y-4">
            <div class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden">
                <button class="faq-question w-full text-left px-6 py-4 bg-gray-50 dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors flex justify-between items-center">
                    <span class="font-semibold text-gray-900 dark:text-white">How quickly do you respond to inquiries?</span>
                    <i class="fas fa-chevron-down text-gray-500 transition-transform"></i>
                </button>
                <div class="faq-answer px-6 py-4 bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700 hidden">
                    <p class="text-gray-600 dark:text-gray-400">We typically respond to all inquiries within 24 business hours. For urgent matters, please call our support line.</p>
                </div>
            </div>
            
            <div class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden">
                <button class="faq-question w-full text-left px-6 py-4 bg-gray-50 dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors flex justify-between items-center">
                    <span class="font-semibold text-gray-900 dark:text-white">Do you offer corporate training?</span>
                    <i class="fas fa-chevron-down text-gray-500 transition-transform"></i>
                </button>
                <div class="faq-answer px-6 py-4 bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700 hidden">
                    <p class="text-gray-600 dark:text-gray-400">Yes, we offer customized training programs for organizations. Please select "Corporate Training" from the subject dropdown and our team will contact you with details.</p>
                </div>
            </div>
            
            <div class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden">
                <button class="faq-question w-full text-left px-6 py-4 bg-gray-50 dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors flex justify-between items-center">
                    <span class="font-semibold text-gray-900 dark:text-white">Can I get a refund for a course?</span>
                    <i class="fas fa-chevron-down text-gray-500 transition-transform"></i>
                </button>
                <div class="faq-answer px-6 py-4 bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700 hidden">
                    <p class="text-gray-600 dark:text-gray-400">We offer a 30-day money-back guarantee for all courses. Please review our refund policy or contact support for assistance.</p>
                </div>
            </div>
            
            <div class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden">
                <button class="faq-question w-full text-left px-6 py-4 bg-gray-50 dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors flex justify-between items-center">
                    <span class="font-semibold text-gray-900 dark:text-white">Do you offer discounts for students?</span>
                    <i class="fas fa-chevron-down text-gray-500 transition-transform"></i>
                </button>
                <div class="faq-answer px-6 py-4 bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700 hidden">
                    <p class="text-gray-600 dark:text-gray-400">Yes, we offer student discounts with valid student ID. Please contact us with your student verification for more information.</p>
                </div>
            </div>
        </div>
    </div>
</section>


<!-- FAQ Accordion Script -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    const faqQuestions = document.querySelectorAll('.faq-question');
    
    faqQuestions.forEach(question => {
        question.addEventListener('click', () => {
            const answer = question.nextElementSibling;
            const icon = question.querySelector('i');
            
            // Toggle current answer
            answer.classList.toggle('hidden');
            icon.style.transform = answer.classList.contains('hidden') ? 'rotate(0deg)' : 'rotate(180deg)';
        });
    });
});
</script>