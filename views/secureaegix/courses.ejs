<% layout("/layouts/boilerplate") -%>

<!-- Hero Section -->
<section class="relative bg-gradient-to-r from-blue-900 to-cyan-800 text-white py-16 overflow-hidden">
    <div class="absolute inset-0 opacity-40 pointer-events-none">
        <canvas id="particleCanvas" class="block w-full h-full"></canvas>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Our Cybersecurity Courses</h1>
        <p class="text-lg text-gray-200 max-w-2xl mx-auto">
            Industry-recognized certifications to advance your cybersecurity career
        </p>
        
        <!-- Search Bar -->
        <div class="max-w-md mx-auto mt-8">
            <div class="relative">
                <form action="/courses" method="GET">
                    <input type="text" name="search" value="<%= search %>" 
                           placeholder="Search courses..." 
                           class="w-full px-5 py-3 pl-12 rounded-lg text-gray-900 dark:text-white dark:bg-gray-800 border border-white/20 focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <i class="fas fa-search absolute left-4 top-3.5 text-gray-400"></i>
                    <% if (search) { %>
                        <a href="/courses" class="absolute right-3 top-3 text-gray-400 hover:text-gray-600">
                            <i class="fas fa-times"></i>
                        </a>
                    <% } %>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Filter Section -->
<section class="py-6 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 top-16 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap gap-3 justify-center">
    <a href="/courses?<%= search ? 'search=' + search + '&' : '' %>level=all" 
       class="px-4 py-2 rounded-full transition-all duration-300 
              <%= (!level || level === 'all') ? 'bg-blue-600 text-white shadow-md' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-blue-600 hover:text-white' %>">
        All Courses
    </a>
    <a href="/courses?<%= search ? 'search=' + search + '&' : '' %>level=beginner" 
       class="px-4 py-2 rounded-full transition-all duration-300 
              <%= level === 'beginner' ? 'bg-blue-600 text-white shadow-md' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-blue-600 hover:text-white' %>">
        Beginner
    </a>
    <a href="/courses?<%= search ? 'search=' + search + '&' : '' %>level=intermediate" 
       class="px-4 py-2 rounded-full transition-all duration-300 
              <%= level === 'intermediate' ? 'bg-blue-600 text-white shadow-md' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-blue-600 hover:text-white' %>">
        Intermediate
    </a>
    <a href="/courses?<%= search ? 'search=' + search + '&' : '' %>level=advanced" 
       class="px-4 py-2 rounded-full transition-all duration-300 
              <%= level === 'advanced' ? 'bg-blue-600 text-white shadow-md' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-blue-600 hover:text-white' %>">
        Advanced
    </a>
    <a href="/courses?<%= search ? 'search=' + search + '&' : '' %>level=expert" 
       class="px-4 py-2 rounded-full transition-all duration-300 
              <%= level === 'expert' ? 'bg-blue-600 text-white shadow-md' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-blue-600 hover:text-white' %>">
        Expert
    </a>
</div>
    </div>
</section>

<!-- Courses Grid -->
<section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Results Count -->
        <div class="mb-6 flex justify-between items-center">
            <p class="text-gray-600 dark:text-gray-400">
                Showing <span class="font-semibold"><%= cources.length %></span> courses
            </p>
            <% if (search) { %>
                <p class="text-gray-600 dark:text-gray-400">
                    Search results for: <span class="font-semibold">"<%= search %>"</span>
                </p>
            <% } %>
        </div>
        
        <!-- Admin Action Buttons (Only visible to admin) -->
        <% if (currUser && currUser.role === 'admin') { %>
            <div class="mb-6 flex gap-3 justify-end">
                <a href="/courses/new" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-all">
                    <i class="fas fa-plus mr-2"></i> Create New Course
                </a>
                <a href="/courses" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-all">
                    <i class="fas fa-cog mr-2"></i> Admin Panel
                </a>
            </div>
        <% } %>
        
        <!-- Courses Grid -->
        <% if (cources && cources.length > 0) { %>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% cources.forEach(course => { %>
                    <div class="course-card bg-white dark:bg-gray-900 rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 relative">
                        
                        <!-- Admin Badges -->
                        <% if (currUser && currUser.role === 'admin') { %>
                            <div class="absolute top-2 right-2 z-20 flex gap-1">
                                <button onclick="toggleStatus('<%= course._id %>', '<%= !course.isActive %>')" 
                                        class="w-8 h-8 rounded-full <%= course.isActive ? 'bg-green-500' : 'bg-red-500' %> text-white flex items-center justify-center hover:scale-110 transition-all"
                                        title="<%= course.isActive ? 'Deactivate Course' : 'Activate Course' %>">
                                    <i class="fas <%= course.isActive ? 'fa-check' : 'fa-ban' %> text-xs"></i>
                                </button>
                                <button onclick="togglePopular('<%= course._id %>', '<%= !course.isPopular %>')" 
                                        class="w-8 h-8 rounded-full <%= course.isPopular ? 'bg-yellow-500' : 'bg-gray-500' %> text-white flex items-center justify-center hover:scale-110 transition-all"
                                        title="<%= course.isPopular ? 'Remove from Popular' : 'Mark as Popular' %>">
                                    <i class="fas fa-star text-xs"></i>
                                </button>
                                <button onclick="toggleNavbar('<%= course._id %>', '<%= !course.showInNavbar %>')" 
                                        class="w-8 h-8 rounded-full <%= course.showInNavbar ? 'bg-blue-500' : 'bg-gray-500' %> text-white flex items-center justify-center hover:scale-110 transition-all"
                                        title="<%= course.showInNavbar ? 'Remove from Navbar' : 'Add to Navbar' %>">
                                    <i class="fas fa-bars text-xs"></i>
                                </button>
                                <button onclick="toggleHomepage('<%= course._id %>', '<%= !course.showInHomepage %>')" 
                                        class="w-8 h-8 rounded-full <%= course.showInHomepage ? 'bg-cyan-600' : 'bg-gray-500' %> text-white flex items-center justify-center hover:scale-110 transition-all"
                                        title="<%= course.showInHomepage ? 'Remove from Homepage' : 'Add to Homepage' %>">
                                    <i class="fas fa-home text-xs"></i>
                                </button>
                            </div>
                        <% } %>
                        
                        <!-- Course Image -->
                        <a href="/courses/<%= course._id %>" class="block relative h-56 overflow-hidden">
                            <% if (course.image && course.image.url) { %>
                                <img src="<%= course.image.url %>" alt="<%= course.title %>" 
                                     class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                            <% } else { %>
                                <div class="w-full h-full bg-gradient-to-br from-blue-600 to-cyan-600 flex items-center justify-center">
                                    <i class="fas fa-shield-alt text-6xl text-white/30"></i>
                                </div>
                            <% } %>
                            
                            <!-- Badges -->
                            <div class="absolute top-4 left-4 flex gap-2">
                                <% if (course.isPopular) { %>
                                    <span class="px-2 py-1 bg-yellow-500 text-white text-xs rounded-full font-semibold">
                                        <i class="fas fa-star mr-1"></i> Popular
                                    </span>
                                <% } %>
                                <% if (course.courseLevel) { %>
                                    <span class="px-2 py-1 bg-blue-600 text-white text-xs rounded-full font-semibold">
                                        <%= course.courseLevel.charAt(0).toUpperCase() + course.courseLevel.slice(1) %>
                                    </span>
                                <% } %>
                            </div>
                            
                            <!-- Price Badge -->
                            <div class="absolute bottom-4 right-4 flex flex-col items-end gap-1">
                                 <% if (course.actualPrice && course.actualPrice < course.price) { %>
                                    <!-- Original Price (Crossed out) -->
                                    <span class="px-2 py-0.5 bg-white/80 backdrop-blur-sm text-gray-500 text-xs rounded-full line-through">
                                        ₹<%= course.price %>
                                    </span>
                                    <!-- Actual Price (Highlighted) -->
                                    <span class="px-3 py-1 bg-gradient-to-r from-green-500 to-emerald-600 text-white text-sm font-bold rounded-full shadow-lg animate-pulse">
                                        ₹<%= course.actualPrice %>
                                </span>
                                <% } else { %>
                                    <!-- Single Price (No discount) -->
                                    <span class="px-3 py-1 bg-white/90 backdrop-blur-sm text-blue-600 text-sm font-bold rounded-full">
                                        ₹<%= course.price %>
                                    </span>
                                <% } %>
                            
                            </div>
                        </a>
                        
                        <div class="p-6">
                            <!-- Course Type -->
                            <div class="text-xs text-blue-600 dark:text-blue-400 font-semibold mb-2">
                                <%= course.courceType %>
                            </div>
                            
                            <!-- Title -->
                            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2 line-clamp-2">
                                <a href="/course/<%= course._id %>" class="hover:text-blue-600 transition-colors">
                                    <%= course.title %>
                                </a>
                            </h3>
                            
                            <!-- Description -->
                            <p class="text-gray-600 dark:text-gray-400 text-sm mb-4 line-clamp-2">
                                <%= course.shortDescription %>
                            </p>
                            
                            <!-- Course Stats -->
                            <div class="flex items-center justify-between mb-4 text-sm">
                                <div class="flex items-center gap-2">
                                    <i class="fas fa-user-graduate text-gray-400"></i>
                                    <span class="text-gray-600 dark:text-gray-400"><%= course.students?.length || 0 %> students</span>
                                </div>
                                <div class="flex items-center gap-1">
                                    <i class="fas fa-star text-yellow-400 text-xs"></i>
                                    <span class="text-gray-600 dark:text-gray-400"><%= course.rating || 4.5 %></span>
                                </div>
                                <div class="flex items-center gap-1">
                                    <i class="far fa-clock text-gray-400"></i>
                                    <span class="text-gray-600 dark:text-gray-400"><%= course.duration || 8 %> days</span>
                                </div>
                            </div>
                            
                            <!-- Instructor -->
                            <div class="flex items-center gap-2 pt-3 border-t border-gray-100 dark:border-gray-700">
                                <div class="w-6 h-6 rounded-full bg-gradient-to-r from-blue-600 to-cyan-500 flex items-center justify-center text-white text-xs font-bold">
                                    <%= course.teacher?.name?.charAt(0).toUpperCase() || 'A' %>
                                </div>
                                <span class="text-sm text-gray-600 dark:text-gray-400">
                                    By <%= course.teacher?.name || 'SecureAaegix' %>
                                </span>
                            </div>
                            
                            <!-- Admin Actions -->
                            <% if (currUser && currUser.role === 'admin') { %>
                                <div class="flex gap-2 mt-4 pt-3 border-t border-gray-100 dark:border-gray-700">
                                    <a href="/courses/<%= course._id %>/edit" class="flex-1 px-3 py-1.5 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700 transition-all text-center">
                                        <i class="fas fa-edit mr-1"></i> Edit
                                    </a>
                                    <button onclick="deleteCourse('<%= course._id %>')" class="flex-1 px-3 py-1.5 bg-red-600 text-white text-sm rounded-lg hover:bg-red-700 transition-all">
                                        <i class="fas fa-trash mr-1"></i> Delete
                                    </button>
                                </div>
                            <% } else { %>
                                <div class="mt-4">
                                    <a href="/course/<%= course._id %>" class="block text-center px-4 py-2 bg-gradient-to-r from-blue-600 to-cyan-600 text-white rounded-lg font-semibold hover:shadow-lg transition-all">
                                        View Course Details
                                        <i class="fas fa-arrow-right ml-2"></i>
                                    </a>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <!-- No Results -->
            <div class="text-center py-16">
                <i class="fas fa-search text-6xl text-gray-400 mb-4"></i>
                <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-2">No courses found</h3>
                <p class="text-gray-600 dark:text-gray-400 mb-6">
                    Try adjusting your search or browse all courses
                </p>
                <a href="/courses" class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-blue-600 to-cyan-600 text-white rounded-lg font-semibold hover:shadow-lg transition-all">
                    View All Courses
                </a>
            </div>
        <% } %>
        
        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="flex justify-center mt-12">
                <nav class="flex items-center gap-2 flex-wrap">
                    <% if (currentPage > 1) { %>
                        <a href="?page=<%= currentPage - 1 %><%= search ? '&search=' + search : '' %>" 
                           class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    <% } %>
                    
                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <% if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                            <a href="?page=<%= i %><%= search ? '&search=' + search : '' %>" 
                               class="px-4 py-2 rounded-lg transition-colors <%= i === currentPage ? 'bg-blue-600 text-white' : 'border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700' %>">
                                <%= i %>
                            </a>
                        <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                            <span class="px-2 text-gray-500">...</span>
                        <% } %>
                    <% } %>
                    
                    <% if (currentPage < totalPages) { %>
                        <a href="?page=<%= currentPage + 1 %><%= search ? '&search=' + search : '' %>" 
                           class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    <% } %>
                </nav>
            </div>
        <% } %>
    </div>
</section>

<!-- Admin Action JavaScript -->
<script>
// Toggle Course Status
async function toggleStatus(courseId, newStatus) {
    try {
        const response = await fetch(`/courses/${courseId}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();
        if (data.success) {
            window.flashMessages?.success(data.message);
            setTimeout(() => location.reload(), 1000);
        } else {
            window.flashMessages?.error(data.message);
        }
    } catch (error) {
        console.error('Error:', error);
        window.flashMessages?.error('Failed to update course status');
    }
}

// Toggle Popular Status
async function togglePopular(courseId, isPopular) {
    try {
        const response = await fetch(`/courses/${courseId}/popular`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();
        if (data.success) {
            window.flashMessages?.success(data.message);
            setTimeout(() => location.reload(), 1000);
        } else {
            window.flashMessages?.error(data.message);
        }
    } catch (error) {
        console.error('Error:', error);
        window.flashMessages?.error('Failed to update popular status');
    }
}

// Toggle Navbar Visibility
async function toggleNavbar(courseId, showInNavbar) {
    try {
        const response = await fetch(`/courses/${courseId}/toggle-navbar`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();
        if (data.success) {
            window.flashMessages?.success(data.message);
            setTimeout(() => location.reload(), 1000);
        } else {
            window.flashMessages?.error(data.message);
        }
    } catch (error) {
        console.error('Error:', error);
        window.flashMessages?.error('Failed to update navbar visibility');
    }
}

// Toggle Homepage Visibility
async function toggleHomepage(courseId, showInHomepage) {
    try {
        const response = await fetch(`/courses/${courseId}/toggle-homepage`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();
        if (data.success) {
            window.flashMessages?.success(data.message);
            setTimeout(() => location.reload(), 1000);
        } else {
            window.flashMessages?.error(data.message);
        }
    } catch (error) {
        console.error('Error:', error);
        window.flashMessages?.error('Failed to update homepage visibility');
    }
}

// Delete Course
async function deleteCourse(courseId) {
    if (confirm('Are you sure you want to delete this course? This action cannot be undone.')) {
        try {
            const response = await fetch(`/courses/${courseId}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await response.json();
            if (data.success) {
                window.flashMessages?.success(data.message);
                setTimeout(() => location.reload(), 1000);
            } else {
                window.flashMessages?.error(data.message);
            }
        } catch (error) {
            console.error('Error:', error);
            window.flashMessages?.error('Failed to delete course');
        }
    }
}
</script>

<style>
.line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
</style>