<% layout("/layouts/boilerplate") -%>

<div class="min-h-screen bg-gradient-to-br from-gray-900 to-black py-8 px-4">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="mb-8 text-center">
            <h1 class="text-4xl font-bold bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent mb-2">
                Edit Course
            </h1>
            <p class="text-gray-400">Update your course information and settings</p>
        </div>

        <!-- Form Container -->
        <div class="bg-gray-900/50 backdrop-blur-xl rounded-2xl border border-gray-700/50 shadow-2xl overflow-hidden">
            <form action="/courses/<%= course._id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="space-y-8 p-8" id="courseForm">
                
                <!-- Progress Steps -->
                <div class="mb-10">
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center space-x-2">
                            <div class="w-8 h-8 rounded-full bg-cyan-500 flex items-center justify-center">
                                <span class="text-sm font-bold">1</span>
                            </div>
                            <span class="text-sm font-semibold">Basic Info</span>
                        </div>
                        <div class="h-1 flex-1 mx-4 bg-gray-700"></div>
                        <div class="flex items-center space-x-2">
                            <div class="w-8 h-8 rounded-full bg-gray-700 flex items-center justify-center">
                                <span class="text-sm font-bold text-gray-400">2</span>
                            </div>
                            <span class="text-sm font-semibold text-gray-400">Pricing</span>
                        </div>
                        <div class="h-1 flex-1 mx-4 bg-gray-700"></div>
                        <div class="flex items-center space-x-2">
                            <div class="w-8 h-8 rounded-full bg-gray-700 flex items-center justify-center">
                                <span class="text-sm font-bold text-gray-400">3</span>
                            </div>
                            <span class="text-sm font-semibold text-gray-400">Display</span>
                        </div>
                    </div>
                </div>

                <!-- Basic Information Section -->
                <div class="space-y-6">
                    <div class="border-l-4 border-cyan-500 pl-4">
                        <h2 class="text-xl font-bold text-white">Basic Information</h2>
                        <p class="text-gray-400 text-sm">Essential details about your course</p>
                    </div>

                    <!-- Title -->
                    <div class="group">
                        <label for="title" class="block mb-3 font-semibold text-gray-200 group-hover:text-cyan-400 transition-colors">
                            Course Title <span class="text-red-500">*</span>
                        </label>
                        <input type="text" id="title" name="title" value="<%= course.title %>" required
                            class="w-full px-5 py-3.5 rounded-xl bg-gray-800/70 border border-gray-700 text-white 
                                   placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-2 
                                   focus:ring-cyan-500/20 transition-all duration-300">
                        <div class="mt-2 text-sm text-gray-400">
                            <span id="title-counter" class="font-mono"><%= course.title?.length || 0 %>/120</span> characters
                        </div>
                    </div>

                    <!-- Description Section -->
                    <div class="grid grid-cols-1 lg:grid-cols-1 gap-6">
                        <!-- Short Description -->
                        <div class="group">
                            <label for="shortDescription" class="block mb-3 font-semibold text-gray-200 group-hover:text-cyan-400 transition-colors">
                                Short Description <span class="text-red-500">*</span>
                            </label>
                            <textarea id="shortDescription" name="shortDescription" required rows="3"
                                class="w-full px-5 py-3.5 rounded-xl bg-gray-800/70 border border-gray-700 text-white 
                                       placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-2 
                                       focus:ring-cyan-500/20 transition-all duration-300"><%= course.shortDescription %></textarea>
                            <div class="mt-2 text-sm text-gray-400">
                                <span id="shortDesc-counter" class="font-mono"><%= course.shortDescription?.length || 0 %>/250</span> characters
                            </div>
                        </div>

                        <!-- Full Description -->
                        <div class="group">
                            <label for="discription" class="block mb-3 font-semibold text-gray-200 group-hover:text-cyan-400 transition-colors">
                                Detailed Description
                            </label>
                            <textarea id="discription" name="discription" rows="6"
                                class="w-full px-5 py-3.5 rounded-xl bg-gray-800/70 border border-gray-700 text-white 
                                       placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-2 
                                       focus:ring-cyan-500/20 transition-all duration-300"><%= course.discription %></textarea>
                            <div class="mt-2 text-sm text-gray-400">
                                <span id="desc-counter" class="font-mono"><%= course.discription?.length || 0 %>/5000</span> characters
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Pricing & Details Section -->
                <div class="space-y-6">
                    <div class="border-l-4 border-cyan-500 pl-4">
                        <h2 class="text-xl font-bold text-white">Pricing & Details</h2>
                        <p class="text-gray-400 text-sm">Set pricing and course specifications</p>
                    </div>

                    <!-- Price Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <!-- Price -->
                        <div class="group">
                            <label for="price" class="block mb-3 font-semibold text-gray-200 group-hover:text-cyan-400 transition-colors">
                                Price <span class="text-red-500">*</span>
                            </label>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400">$</span>
                                <input type="number" id="price" name="price" value="<%= course.price %>" required min="0" step="0.01"
                                    class="w-full pl-10 pr-5 py-3.5 rounded-xl bg-gray-800/70 border border-gray-700 text-white 
                                           placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-2 
                                           focus:ring-cyan-500/20 transition-all duration-300">
                            </div>
                        </div>

                        <!-- Actual Price -->
                        <div class="group">
                            <label for="actualPrice" class="block mb-3 font-semibold text-gray-200 group-hover:text-cyan-400 transition-colors">
                                Actual Price <span class="text-red-500">*</span>
                            </label>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400">$</span>
                                <input type="number" id="actualPrice" name="actualPrice" value="<%= course.actualPrice %>" required min="0" step="0.01"
                                    class="w-full pl-10 pr-5 py-3.5 rounded-xl bg-gray-800/70 border border-gray-700 text-white 
                                           placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-2 
                                           focus:ring-cyan-500/20 transition-all duration-300">
                            </div>
                        </div>

                        <!-- Discount Percentage -->
                        <div class="group">
                            <label class="block mb-3 font-semibold text-gray-200 group-hover:text-cyan-400 transition-colors">
                                Discount
                            </label>
                            <div class="px-5 py-3.5 rounded-xl bg-gray-800/70 border border-gray-700">
                                <span id="discountPercentage" class="text-2xl font-bold text-green-400">
                                    <%= Math.round(((course.price - course.actualPrice) / course.price) * 100) || 0 %>%
                                </span>
                                <span class="text-gray-400 text-sm ml-2">off</span>
                            </div>
                        </div>
                    </div>

                    <!-- Course Type, Level & Duration -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <!-- Course Type -->
                        <div class="group">
                            <label for="courceType" class="block mb-3 font-semibold text-gray-200 group-hover:text-cyan-400 transition-colors">
                                Course Type <span class="text-red-500">*</span>
                            </label>
                            <div class="relative">
                                <select id="courceType" name="courceType" required
                                    class="w-full px-5 py-3.5 rounded-xl bg-gray-800/70 border border-gray-700 text-white 
                                           focus:outline-none focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20 
                                           appearance-none transition-all duration-300">
                                    <option value="CYBERSECURITY" <%= course.courceType === 'CYBERSECURITY' ? 'selected' : '' %>>🔒 Cybersecurity</option>
                                    <option value="WEB DEV" <%= course.courceType === 'WEB DEV' ? 'selected' : '' %>>💻 Web Development</option>
                                    <option value="ADVANCED" <%= course.courceType === 'ADVANCED' ? 'selected' : '' %>>🚀 Advanced Topics</option>
                                    <option value="MACHINE LEARNING" <%= course.courceType === 'MACHINE LEARNING' ? 'selected' : '' %>>🤖 Machine Learning</option>
                                    <option value="ETHICAL HACKING" <%= course.courceType === 'ETHICAL HACKING' ? 'selected' : '' %>>🎯 Ethical Hacking</option>
                                    <option value="DATA SCIENCE" <%= course.courceType === 'DATA SCIENCE' ? 'selected' : '' %>>📊 Data Science</option>
                                    <option value="ARTIFICIAL INTELLIGENCE" <%= course.courceType === 'ARTIFICIAL INTELLIGENCE' ? 'selected' : '' %>>🧠 Artificial Intelligence</option>
                                    <option value="other" <%= course.courceType === 'other' ? 'selected' : '' %>>✨ Other</option>
                                </select>
                                <div class="absolute right-4 top-1/2 transform -translate-y-1/2 pointer-events-none">
                                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                                    </svg>
                                </div>
                            </div>
                        </div>

                        <!-- Course Level -->
                        <div class="group">
                            <label for="courseLevel" class="block mb-3 font-semibold text-gray-200 group-hover:text-cyan-400 transition-colors">
                                Course Level <span class="text-red-500">*</span>
                            </label>
                            <div class="relative">
                                <select id="courseLevel" name="courseLevel" required
                                    class="w-full px-5 py-3.5 rounded-xl bg-gray-800/70 border border-gray-700 text-white 
                                           focus:outline-none focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20 
                                           appearance-none transition-all duration-300">
                                    <option value="beginner" <%= course.courseLevel === 'beginner' ? 'selected' : '' %>>🌱 Beginner</option>
                                    <option value="intermediate" <%= course.courseLevel === 'intermediate' ? 'selected' : '' %>>📘 Intermediate</option>
                                    <option value="advanced" <%= course.courseLevel === 'advanced' ? 'selected' : '' %>>🚀 Advanced</option>
                                    <option value="expert" <%= course.courseLevel === 'expert' ? 'selected' : '' %>>🏆 Expert</option>
                                </select>
                                <div class="absolute right-4 top-1/2 transform -translate-y-1/2 pointer-events-none">
                                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                                    </svg>
                                </div>
                            </div>
                        </div>

                        <!-- Duration -->
                        <div class="group">
                            <label for="duration" class="block mb-3 font-semibold text-gray-200 group-hover:text-cyan-400 transition-colors">
                                Duration (days)
                            </label>
                            <div class="relative">
                                <span class="absolute right-4 top-1/2 transform -translate-y-1/2 text-gray-400">days</span>
                                <input type="number" id="duration" name="duration" value="<%= course.duration %>" min="1" 
                                    class="w-full pr-16 pl-5 py-3.5 rounded-xl bg-gray-800/70 border border-gray-700 text-white 
                                           placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-2 
                                           focus:ring-cyan-500/20 transition-all duration-300">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Course Content Section -->
                <div class="space-y-6">
                    <div class="border-l-4 border-cyan-500 pl-4">
                        <h2 class="text-xl font-bold text-white">Course Content</h2>
                        <p class="text-gray-400 text-sm">Add prerequisites, learning outcomes, and what's included</p>
                    </div>

                    <!-- Prerequisites -->
                    <div class="group">
                        <label for="prerequisites" class="block mb-3 font-semibold text-gray-200 group-hover:text-cyan-400 transition-colors">
                            Prerequisites (comma separated)
                        </label>
                        <input type="text" id="prerequisites" name="prerequisites" 
                               value="<%= course.prerequisites ? course.prerequisites.join(', ') : '' %>"
                               placeholder="Basic networking, Linux fundamentals, Programming basics"
                               class="w-full px-5 py-3.5 rounded-xl bg-gray-800/70 border border-gray-700 text-white 
                                      placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-2 
                                      focus:ring-cyan-500/20 transition-all duration-300">
                        <p class="mt-2 text-sm text-gray-400">Separate each prerequisite with a comma</p>
                    </div>

                    <!-- Learning Outcomes -->
                    <div class="group">
                        <label for="learningOutcomes" class="block mb-3 font-semibold text-gray-200 group-hover:text-cyan-400 transition-colors">
                            Learning Outcomes (comma separated)
                        </label>
                        <input type="text" id="learningOutcomes" name="learningOutcomes" 
                               value="<%= course.learningOutcomes ? course.learningOutcomes.join(', ') : '' %>"
                               placeholder="Conduct penetration tests, Write exploits, Analyze malware"
                               class="w-full px-5 py-3.5 rounded-xl bg-gray-800/70 border border-gray-700 text-white 
                                      placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-2 
                                      focus:ring-cyan-500/20 transition-all duration-300">
                        <p class="mt-2 text-sm text-gray-400">Separate each outcome with a comma</p>
                    </div>

                    <!-- What's Included -->
                    <div class="group">
                        <label for="includes" class="block mb-3 font-semibold text-gray-200 group-hover:text-cyan-400 transition-colors">
                            What's Included (comma separated)
                        </label>
                        <input type="text" id="includes" name="includes" 
                               value="<%= course.includes ? course.includes.join(', ') : '' %>"
                               placeholder="Video lectures, Lab access, Certificate of completion"
                               class="w-full px-5 py-3.5 rounded-xl bg-gray-800/70 border border-gray-700 text-white 
                                      placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-2 
                                      focus:ring-cyan-500/20 transition-all duration-300">
                        <p class="mt-2 text-sm text-gray-400">Separate each item with a comma</p>
                    </div>
                </div>


                <!-- Teacher/Mentor Selection -->
<div class="group">
    <label for="teacher" class="block mb-3 font-semibold text-gray-200 group-hover:text-cyan-400 transition-colors">
        Course Mentor/Teacher <span class="text-red-500">*</span>
    </label>
    <div class="relative">
        <select id="teacher" name="teacher" required
            class="w-full px-5 py-3.5 rounded-xl bg-gray-800/70 border border-gray-700 text-white 
                   focus:outline-none focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20 
                   appearance-none transition-all duration-300">
            <option value="" class="bg-gray-800">Select Teacher/Mentor</option>
            <% if(teachers && teachers.length > 0) { %>
                <% teachers.forEach(teacher => { %>
                    <option value="<%= teacher._id %>" 
                        <%= course.teacher && course.teacher.toString() === teacher._id.toString() ? 'selected' : '' %> 
                        class="bg-gray-800">
                        👨‍🏫 <%= teacher.name %> (<%= teacher.email %>)
                    </option>
                <% }) %>
            <% } else { %>
                <option value="" disabled class="bg-gray-800">No teachers available. Please add teachers first.</option>
            <% } %>
        </select>
        <div class="absolute right-4 top-1/2 transform -translate-y-1/2 pointer-events-none">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
        </div>
    </div>
    <p class="mt-2 text-sm text-gray-400">Select the instructor who will teach this course</p>
</div>

                <!-- Display Settings Section -->
                <div class="space-y-6">
                    <div class="border-l-4 border-cyan-500 pl-4">
                        <h2 class="text-xl font-bold text-white">Display Settings</h2>
                        <p class="text-gray-400 text-sm">Control where and how the course appears</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Add to Homepage -->
                        <label class="flex items-center space-x-3 p-4 rounded-xl bg-gray-800/50 hover:bg-gray-800/70 transition-all cursor-pointer">
                            <input type="checkbox" name="addInHomePage" <%= course.addInHomePage ? "checked" : "" %>
                                   class="w-5 h-5 rounded-lg bg-gray-700 border-gray-600 text-cyan-500 focus:ring-cyan-500">
                            <div>
                                <span class="font-semibold text-white">Show on Homepage</span>
                                <p class="text-sm text-gray-400">Display course on the main landing page</p>
                            </div>
                        </label>

                        <!-- Mark as Popular -->
                        <label class="flex items-center space-x-3 p-4 rounded-xl bg-gray-800/50 hover:bg-gray-800/70 transition-all cursor-pointer">
                            <input type="checkbox" name="isPopular" <%= course.isPopular ? "checked" : "" %>
                                   class="w-5 h-5 rounded-lg bg-gray-700 border-gray-600 text-yellow-500 focus:ring-yellow-500">
                            <div>
                                <span class="font-semibold text-white">Mark as Popular</span>
                                <p class="text-sm text-gray-400">Featured as a popular course</p>
                            </div>
                        </label>

                        <!-- Active Status -->
                        <label class="flex items-center space-x-3 p-4 rounded-xl bg-gray-800/50 hover:bg-gray-800/70 transition-all cursor-pointer">
                            <input type="checkbox" name="isActive" <%= course.isActive ? "checked" : "" %>
                                   class="w-5 h-5 rounded-lg bg-gray-700 border-gray-600 text-green-500 focus:ring-green-500">
                            <div>
                                <span class="font-semibold text-white">Active Course</span>
                                <p class="text-sm text-gray-400">Make course available to students</p>
                            </div>
                        </label>

                        <!-- Show in Navbar -->
                        <label class="flex items-center space-x-3 p-4 rounded-xl bg-gray-800/50 hover:bg-gray-800/70 transition-all cursor-pointer">
                            <input type="checkbox" id="showInNavbar" name="showInNavbar" <%= course.showInNavbar ? "checked" : "" %>
                                   class="w-5 h-5 rounded-lg bg-gray-700 border-gray-600 text-cyan-500 focus:ring-cyan-500">
                            <div>
                                <span class="font-semibold text-white">Show in Navigation</span>
                                <p class="text-sm text-gray-400">Add direct link in navbar</p>
                            </div>
                        </label>
                    </div>

                    <!-- Navbar Settings (conditional) -->
                    <div id="navbarSettings" class="<%= course.showInNavbar ? '' : 'hidden' %> grid grid-cols-1 md:grid-cols-2 gap-6 mt-4 p-4 rounded-xl bg-gray-800/30 border border-gray-700">
                        <div>
                            <label for="navbarButtonText" class="block text-sm font-medium text-gray-300 mb-2">
                                Navbar Button Text
                            </label>
                            <input type="text" id="navbarButtonText" name="navbarButtonText" 
                                   value="<%= course.navbarButtonText || '' %>"
                                   placeholder="e.g., OSCP Certification"
                                   class="w-full px-4 py-2 rounded-lg bg-gray-800/70 border border-gray-700 text-white">
                        </div>
                        <div>
                            <label for="navbarButtonColor" class="block text-sm font-medium text-gray-300 mb-2">
                                Button Color
                            </label>
                            <select id="navbarButtonColor" name="navbarButtonColor"
                                    class="w-full px-4 py-2 rounded-lg bg-gray-800/70 border border-gray-700 text-white">
                                <option value="blue" <%= course.navbarButtonColor === 'blue' ? 'selected' : '' %>>Blue</option>
                                <option value="cyan" <%= course.navbarButtonColor === 'cyan' ? 'selected' : '' %>>Cyan</option>
                                <option value="purple" <%= course.navbarButtonColor === 'purple' ? 'selected' : '' %>>Purple</option>
                                <option value="green" <%= course.navbarButtonColor === 'green' ? 'selected' : '' %>>Green</option>
                                <option value="red" <%= course.navbarButtonColor === 'red' ? 'selected' : '' %>>Red</option>
                            </select>
                        </div>
                        <div>
                            <label for="navbarButtonIcon" class="block text-sm font-medium text-gray-300 mb-2">
                                Button Icon
                            </label>
                            <select id="navbarButtonIcon" name="navbarButtonIcon"
                                    class="w-full px-4 py-2 rounded-lg bg-gray-800/70 border border-gray-700 text-white">
                                <option value="fa-graduation-cap" <%= course.navbarButtonIcon === 'fa-graduation-cap' ? 'selected' : '' %>>🎓 Graduation Cap</option>
                                <option value="fa-certificate" <%= course.navbarButtonIcon === 'fa-certificate' ? 'selected' : '' %>>📜 Certificate</option>
                                <option value="fa-shield-alt" <%= course.navbarButtonIcon === 'fa-shield-alt' ? 'selected' : '' %>>🛡️ Shield</option>
                                <option value="fa-laptop-code" <%= course.navbarButtonIcon === 'fa-laptop-code' ? 'selected' : '' %>>💻 Laptop</option>
                                <option value="fa-user-secret" <%= course.navbarButtonIcon === 'fa-user-secret' ? 'selected' : '' %>>🕵️ User Secret</option>
                                <option value="fa-bug" <%= course.navbarButtonIcon === 'fa-bug' ? 'selected' : '' %>>🐛 Bug</option>
                            </select>
                        </div>
                        <div>
                            <label for="navbarOrder" class="block text-sm font-medium text-gray-300 mb-2">
                                Order (lower = higher)
                            </label>
                            <input type="number" id="navbarOrder" name="navbarOrder" 
                                   value="<%= course.navbarOrder || 0 %>"
                                   class="w-full px-4 py-2 rounded-lg bg-gray-800/70 border border-gray-700 text-white">
                        </div>
                    </div>
                </div>

                <!-- Media Upload Section -->
                <div class="space-y-6">
                    <div class="border-l-4 border-cyan-500 pl-4">
                        <h2 class="text-xl font-bold text-white">Course Image</h2>
                        <p class="text-gray-400 text-sm">Update course thumbnail</p>
                    </div>

                    <div class="space-y-4">
                        <div class="group">
                            <label for="image" class="block mb-3 font-semibold text-gray-200 group-hover:text-cyan-400 transition-colors">
                                Course Thumbnail
                            </label>
                            <% if(course.image && course.image.url) { %>
                                <div class="mb-4">
                                    <img src="<%= course.image.url %>" alt="<%= course.title %>" 
                                         class="w-40 h-24 object-cover rounded-lg border border-gray-700"/>
                                    <p class="text-xs text-gray-400 mt-1">Current image</p>
                                </div>
                            <% } %>
                            <input type="file" id="image" name="image" accept="image/*"
                                   class="w-full px-5 py-3.5 rounded-xl bg-gray-800/70 border-2 border-dashed border-gray-700 
                                          text-white file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 
                                          file:text-sm file:font-semibold file:bg-cyan-500/20 file:text-cyan-400 
                                          hover:file:bg-cyan-500/30 hover:border-cyan-500/50 transition-all duration-300 
                                          focus:outline-none focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20">
                            <p class="mt-2 text-sm text-gray-400">Recommended: 1280x720px, max 5MB (leave empty to keep current)</p>
                        </div>

                        <!-- Preview Section -->
                        <div class="mt-4">
                            <label class="block mb-3 font-semibold text-gray-200">Preview</label>
                            <div id="imagePreview" class="w-full h-48 rounded-xl bg-gray-800/50 border-2 border-dashed border-gray-700 
                                                       flex items-center justify-center overflow-hidden">
                                <% if(course.image && course.image.url) { %>
                                    <img src="<%= course.image.url %>" class="w-full h-full object-cover" alt="Preview">
                                <% } else { %>
                                    <div class="text-center">
                                        <svg class="w-12 h-12 text-gray-600 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                        </svg>
                                        <p class="text-gray-500">Select new image to preview</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="pt-8 border-t border-gray-800">
                    <div class="flex flex-col sm:flex-row gap-4">
                        <button type="submit"
                            class="flex-1 bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-600 hover:to-blue-700 
                                   text-white font-bold py-4 px-8 rounded-xl transition-all duration-300 
                                   transform hover:scale-[1.02] active:scale-[0.98] shadow-lg hover:shadow-xl 
                                   hover:shadow-cyan-500/20 flex items-center justify-center space-x-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                            </svg>
                            <span>Update Course</span>
                        </button>
                        
                        <a href="/courses" 
                            class="flex-1 bg-gray-800 hover:bg-gray-700 text-gray-300 font-bold py-4 px-8 
                                   rounded-xl transition-all duration-300 border border-gray-700 text-center">
                            Cancel
                        </a>
                        
                        <a href="/courses/<%= course._id %>" 
                            class="flex-1 bg-gray-800/50 hover:bg-gray-800 text-gray-300 font-bold py-4 px-8 
                                   rounded-xl transition-all duration-300 border border-gray-700 text-center">
                            View Course
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- JavaScript -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Character counters
        const titleInput = document.getElementById('title');
        const shortDescInput = document.getElementById('shortDescription');
        const descInput = document.getElementById('discription');
        const priceInput = document.getElementById('price');
        const actualPriceInput = document.getElementById('actualPrice');
        const discountElement = document.getElementById('discountPercentage');
        const imageInput = document.getElementById('image');
        const imagePreview = document.getElementById('imagePreview');
        const showInNavbar = document.getElementById('showInNavbar');
        const navbarSettings = document.getElementById('navbarSettings');

        // Title counter
        if (titleInput) {
            titleInput.addEventListener('input', function() {
                const counter = document.getElementById('title-counter');
                counter.textContent = `${this.value.length}/120`;
            });
        }

        // Short description counter
        if (shortDescInput) {
            shortDescInput.addEventListener('input', function() {
                const counter = document.getElementById('shortDesc-counter');
                counter.textContent = `${this.value.length}/250`;
            });
        }

        // Description counter
        if (descInput) {
            descInput.addEventListener('input', function() {
                const counter = document.getElementById('desc-counter');
                counter.textContent = `${this.value.length}/5000`;
            });
        }

        // Calculate discount
        function calculateDiscount() {
            const price = parseFloat(priceInput?.value) || 0;
            const actualPrice = parseFloat(actualPriceInput?.value) || 0;
            
            if (price > 0 && actualPrice < price) {
                const discount = ((price - actualPrice) / price * 100).toFixed(1);
                if (discountElement) {
                    discountElement.textContent = `${discount}%`;
                    if (discount >= 50) {
                        discountElement.className = 'text-2xl font-bold text-red-400';
                    } else if (discount >= 20) {
                        discountElement.className = 'text-2xl font-bold text-yellow-400';
                    } else {
                        discountElement.className = 'text-2xl font-bold text-green-400';
                    }
                }
            } else if (discountElement) {
                discountElement.textContent = '0%';
                discountElement.className = 'text-2xl font-bold text-green-400';
            }
        }

        if (priceInput && actualPriceInput) {
            priceInput.addEventListener('input', calculateDiscount);
            actualPriceInput.addEventListener('input', calculateDiscount);
        }

        // Image preview
        if (imageInput) {
            imageInput.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(event) {
                        if (imagePreview) {
                            imagePreview.innerHTML = `<img src="${event.target.result}" class="w-full h-full object-cover rounded-xl" alt="Preview">`;
                        }
                    }
                    reader.readAsDataURL(file);
                }
            });
        }

        // Show/hide navbar settings
        if (showInNavbar && navbarSettings) {
            showInNavbar.addEventListener('change', function() {
                if (this.checked) {
                    navbarSettings.classList.remove('hidden');
                } else {
                    navbarSettings.classList.add('hidden');
                }
            });
        }

        // Form validation
        const courseForm = document.getElementById('courseForm');
        if (courseForm) {
            courseForm.addEventListener('submit', function(e) {
                const price = parseFloat(priceInput?.value) || 0;
                const actualPrice = parseFloat(actualPriceInput?.value) || 0;
                
                if (actualPrice > price) {
                    e.preventDefault();
                    alert('Actual price cannot be higher than original price');
                    actualPriceInput?.focus();
                }
            });
        }
    });
</script>