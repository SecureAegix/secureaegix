            </div>
            <div class="text-center p-6 bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-800/10 rounded-2xl">
                <div class="text-4xl font-bold text-blue-600 dark:text-blue-400">99<span class="text-lg">%</span></div>
                <p class="text-sm text-gray-600 dark:text-gray-400 mt-2">Containment Rate</p>
            </div>
            <div class="text-center p-6 bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900/20 dark:to-green-800/10 rounded-2xl">
                <div class="text-4xl font-bold text-green-600 dark:text-green-400">₹5Cr<span class="text-lg"></span></div>
                <p class="text-sm text-gray-600 dark:text-gray-400 mt-2">Avg Cost Saved</p>
            </div>
            <div class="text-center p-6 bg-gradient-to-br from-purple-50 to-purple-100 dark:from-purple-900/20 dark:to-purple-800/10 rounded-2xl">
                <div class="text-4xl font-bold text-purple-600 dark:text-purple-400">500+</div>
                <p class="text-sm text-gray-600 dark:text-gray-400 mt-2">Incidents Handled</p>
            </div>
        </div>
    </div>
</section>

<!-- IR Lifecycle - Modern Card Design -->
