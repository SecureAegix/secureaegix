                        <ul class="mt-3 space-y-1 text-sm text-gray-500">
                            <li class="flex items-center gap-2"><i class="fas fa-check-circle text-green-500 text-xs"></i> 24/7 Monitoring</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check-circle text-green-500 text-xs"></i> Alert Triage</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check-circle text-green-500 text-xs"></i> Initial Investigation</li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <!-- Containment -->
            <div class="bg-white dark:bg-gray-900 rounded-xl p-6 hover:shadow-xl transition-all group">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
