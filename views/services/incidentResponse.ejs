                            <li class="flex items-center gap-2"><i class="fas fa-check-circle text-green-500 text-xs"></i> Root Cause Analysis</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check-circle text-green-500 text-xs"></i> IR Plan Updates</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check-circle text-green-500 text-xs"></i> Security Improvements</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

