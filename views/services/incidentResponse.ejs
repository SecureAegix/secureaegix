                            <li class="flex items-center gap-2"><i class="fas fa-check-circle text-green-500 text-xs"></i> Team Training & Drills</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check-circle text-green-500 text-xs"></i> Tool Setup & Configuration</li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <!-- Detection & Analysis -->
