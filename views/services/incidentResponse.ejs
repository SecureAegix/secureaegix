                        <span class="text-orange-600 font-bold text-xl">4</span>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Eradication</h3>
                        <p class="text-gray-600 dark:text-gray-400 text-sm">Remove threats, malware, and attacker access from the environment.</p>
                        <ul class="mt-3 space-y-1 text-sm text-gray-500">
                            <li class="flex items-center gap-2"><i class="fas fa-check-circle text-green-500 text-xs"></i> Malware Removal</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check-circle text-green-500 text-xs"></i> Backdoor Closure</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check-circle text-green-500 text-xs"></i> Vulnerability Patching</li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <!-- Recovery -->
            <div class="bg-white dark:bg-gray-900 rounded-xl p-6 hover:shadow-xl transition-all group">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                        <span class="text-green-600 font-bold text-xl">5</span>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Recovery</h3>
                        <p class="text-gray-600 dark:text-gray-400 text-sm">Restore systems and return to normal operations safely.</p>
