                            <li class="flex items-center gap-2"><i class="fas fa-check-circle text-green-500 text-xs"></i> System Restoration</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check-circle text-green-500 text-xs"></i> Data Recovery</li>
                            <li class="flex items-center gap-2"><i class="fas fa-check-circle text-green-500 text-xs"></i> Monitoring for Recurrence</li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <!-- Lessons Learned -->
            <div class="bg-white dark:bg-gray-900 rounded-xl p-6 hover:shadow-xl transition-all group">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-red-100 dark:bg-red-900/30 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                        <span class="text-red-600 font-bold text-xl">6</span>
