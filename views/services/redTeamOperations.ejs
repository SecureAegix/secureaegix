                    <div class="text-3xl font-bold text-red-600">100%</div>
                    <div class="text-sm text-gray-600 dark:text-gray-400">Real-world Simulation</div>
                </div>
                <div class="bg-cyan-50 dark:bg-cyan-900/20 rounded-xl p-4 text-center">
                    <div class="text-3xl font-bold text-cyan-600">24/7</div>
                    <div class="text-sm text-gray-600 dark:text-gray-400">Continuous Operations</div>
                </div>
                <div class="bg-purple-50 dark:bg-purple-900/20 rounded-xl p-4 text-center">
                    <div class="text-3xl font-bold text-purple-600">0%</div>
                    <div class="text-sm text-gray-600 dark:text-gray-400">Prior Knowledge</div>
